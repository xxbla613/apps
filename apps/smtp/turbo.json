{
  "$schema": "https://turbo.build/schema.v2.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "SALEOR_API_URL",
        "APP_URL",
        "SECRET_KEY",
        "NODE_ENV"
      ]
    },
    "deploy": {
      "dependsOn": ["build"],
      "env": [
        "ALLOWED_DOMAIN_PATTERN",
        "APL",
        "APP_API_BASE_URL",
        "APP_IFRAME_BASE_URL",
        "NEXT_PUBLIC_SENTRY_DSN",
        "REST_APL_ENDPOINT",
        "REST_APL_TOKEN",
        "SECRET_KEY",
        "SENTRY_AUTH_TOKEN",
        "SENTRY_PROJECT",
        "FALLBACK_SMTP_HOST",
        "FALLBACK_SMTP_PORT",
        "FALLBACK_SMTP_USER",
        "FALLBACK_SMTP_PASSWORD",
        "MANIFEST_APP_ID"
      ]
    }
  }
}
